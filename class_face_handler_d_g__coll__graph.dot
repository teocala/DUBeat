  Node3 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" QGLpoints_face" ,fontname="Helvetica"];
  Node3 [label="QGaussLegendreSimplex\l\< dim - 1 \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$class_q_gauss_legendre_simplex.html",tooltip=" "];
  Node4 -> Node3 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node4 [label="dealii::Quadrature\l\< dim \>",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
