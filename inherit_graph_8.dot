  Node5 -> Node0 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node0 [label="QGaussLegendreSimplex\l\< dim \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$class_q_gauss_legendre_simplex.html",tooltip="Class representing the Gauss-Legendre quadrature formula on simplex elements."];
  Node5 -> Node7 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
