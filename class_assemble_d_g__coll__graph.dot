  Node3 -> Node2 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node3 [label="VolumeHandlerDG\< dim \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$class_volume_handler_d_g.html",tooltip="Class for the main operations on a discontinuous Galerkin volume element."];
  Node4 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" QGLpoints_face" ,fontname="Helvetica"];
  Node4 [label="QGaussLegendreSimplex\l\< dim - 1 \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$class_q_gauss_legendre_simplex.html",tooltip=" "];
  Node5 -> Node4 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node5 [label="dealii::Quadrature\l\< dim \>",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node6 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" vol_handler" ,fontname="Helvetica"];
  Node6 [label="VolumeHandlerDG\< lifex\l::dim \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$class_volume_handler_d_g.html",tooltip=" "];
}
